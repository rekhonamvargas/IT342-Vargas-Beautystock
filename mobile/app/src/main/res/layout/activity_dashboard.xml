<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient">

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-70dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/bg_orb_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bs_card"
                android:elevation="0dp"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_brand_chip"
                    android:paddingLeft="10dp"
                    android:paddingTop="4dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="4dp"
                    android:text="Dashboard"
                    android:textAppearance="@style/TextAppearance.LabelMedium"
                    android:fontFamily="@font/poppins" />

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Welcome"
                    android:textAppearance="@style/TextAppearance.HeadlineMedium"
                    android:fontFamily="@font/lora" />

                <TextView
                    android:id="@+id/tvRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="BeautyStock dashboard"
                    android:textAppearance="@style/TextAppearance.BodyMedium"
                    android:fontFamily="@font/poppins" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_btn_secondary"
                    android:padding="14dp"
                    android:text="Preview mode: Dashboard is intentionally not completed yet."
                    android:textAppearance="@style/TextAppearance.BodySmall"
                    android:fontFamily="@font/poppins" />

                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_btn_primary"
                    android:text="Logout"
                    android:textAllCaps="false"
                    android:textAppearance="@style/TextAppearance.LabelLarge"
                    android:fontFamily="@font/poppins" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
